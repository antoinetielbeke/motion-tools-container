# Motion Tools Container - Environment Configuration Example
# Copy this file to .env and customize for your deployment

# ============================================================================
# General Configuration
# ============================================================================
DOMAIN=localhost:8080
PROTOCOL=http
TIMEZONE=UTC

# ============================================================================
# Port Configuration
# ============================================================================
HTTP_PORT=8080
HTTPS_PORT=8443
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# ============================================================================
# Database Configuration
# ============================================================================
DB_ROOT_PASSWORD=changeme_root_password
DB_NAME=antragsgruen
DB_USER=antragsgruen
DB_PASSWORD=changeme_db_password

# ============================================================================
# SMTP/Email Configuration
# ============================================================================
# For development with Mailpit (default):
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_AUTH_TYPE=none
SMTP_USERNAME=
SMTP_PASSWORD=

# For production SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_AUTH_TYPE=login
# SMTP_USERNAME=noreply@example.com
# SMTP_PASSWORD=your_smtp_password

# Email sender information
MAIL_FROM_EMAIL=noreply@localhost
MAIL_FROM_NAME=Antragsgruen

# ============================================================================
# Application Configuration
# ============================================================================
# Security - Generate with: openssl rand -base64 32
RANDOM_SEED=CHANGE_THIS_TO_A_RANDOM_STRING_32_CHARACTERS_LONG

# Language (supported: en, de, fr, etc.)
BASE_LANGUAGE=en

# Antragsgruen Mode: "single-site" or "multisite"
# - single-site: One site/consultation (simpler, recommended for beginners)
# - multisite: Multiple sites with subdomains (advanced)
ANTRAGSGRUEN_MODE=single-site

# For single-site mode, set to false. For multisite mode, set to true.
MULTISITE_MODE=false

# ============================================================================
# Database Initialization (Development)
# ============================================================================
# Automatically initialize database on first run (recommended for development)
# Set to false for production deployments where you manage the database manually
AUTO_INIT_DB=true

# Default site configuration (only used if AUTO_INIT_DB=true)
# For single-site mode:
DEFAULT_SITE_SUBDOMAIN=demo
DEFAULT_SITE_TITLE=Demo Site
DEFAULT_SITE_ORG=Demo Organization
DEFAULT_CONSULTATION_TITLE=Main Consultation
DEFAULT_CONSULTATION_PATH=main

# ============================================================================
# Database Migrations
# ============================================================================
# Run migrations on startup (not needed if AUTO_INIT_DB=true)
RUN_MIGRATIONS=false

# ============================================================================
# Production Configuration Notes
# ============================================================================
# For production deployments:
# 1. Set AUTO_INIT_DB=false (manage database manually)
# 2. Generate secure passwords: openssl rand -base64 32
# 3. Use PROTOCOL=https with proper SSL certificates
# 4. Configure proper SMTP server (not MailHog)
# 5. Set strong DB_ROOT_PASSWORD and DB_PASSWORD
# 6. Set unique RANDOM_SEED value
# 7. Consider using multisite mode if needed (ANTRAGSGRUEN_MODE=multisite, MULTISITE_MODE=true)
