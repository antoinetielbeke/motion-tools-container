# Motion Tools Container - Environment Configuration
# Based on Antragsgruen v4.17-volt environment variable support
# See: https://github.com/CatoTH/antragsgruen/blob/main/docs/environment-variables.md

# =============================================================================
# Database (Required)
# =============================================================================
DB_NAME=antragsgruen
DB_USER=antragsgruen
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=rootpassword
# DB_PORT=3306
# DB_CHARSET=utf8mb4
# TABLE_PREFIX=

# =============================================================================
# Application (Required)
# =============================================================================
# Generate RANDOM_SEED with: openssl rand -base64 32
RANDOM_SEED=

# Domain and protocol
APP_DOMAIN=localhost:8080
APP_PROTOCOL=http

# =============================================================================
# Application (Optional)
# =============================================================================
BASE_LANGUAGE=en
MULTISITE_MODE=false
# PREPEND_WWW_TO_SUBDOMAIN=false
# ALLOW_REGISTRATION=true
# CONFIRM_EMAIL_ADDRESSES=true

# =============================================================================
# Redis (Optional but recommended)
# =============================================================================
# Redis is automatically enabled when REDIS_HOST is set
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# =============================================================================
# Mail Configuration
# =============================================================================
# Option 1: Symfony Mailer DSN (recommended)
MAILER_DSN=smtp://mailpit:1025

# Option 2: Individual SMTP settings (alternative to MAILER_DSN)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_ENCRYPTION=tls

# Sender information
MAIL_FROM_EMAIL=noreply@localhost
MAIL_FROM_NAME=Antragsgruen

# =============================================================================
# Tool Paths (Optional)
# =============================================================================
# IMAGE_MAGICK_PATH=/usr/bin/convert
# WEASYPRINT_PATH=/usr/bin/weasyprint
# PDFUNITE_PATH=/usr/bin/pdfunite

# =============================================================================
# Container Settings
# =============================================================================
HTTP_PORT=8080
RUN_MIGRATIONS=true

# Development only - Mailpit web UI
MAILPIT_WEB_PORT=8025
