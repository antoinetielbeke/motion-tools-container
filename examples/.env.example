# Motion Tools Container - Environment Configuration
# Based on Antragsgruen v4.17-volt environment variable support
# See: https://github.com/CatoTH/antragsgruen/blob/main/docs/environment-variables.md

# =============================================================================
# Database (Required)
# =============================================================================
DB_NAME=antragsgruen
DB_USER=antragsgruen
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=rootpassword
# DB_PORT=3306
# DB_CHARSET=utf8mb4
# TABLE_PREFIX=

# =============================================================================
# Application (Required)
# =============================================================================
# Generate RANDOM_SEED with: openssl rand -base64 32
RANDOM_SEED=

# Domain and protocol
APP_DOMAIN=localhost:8080
APP_PROTOCOL=http

# =============================================================================
# Application (Optional)
# =============================================================================
BASE_LANGUAGE=en
MULTISITE_MODE=false
# PREPEND_WWW_TO_SUBDOMAIN=false
# ALLOW_REGISTRATION=true
# CONFIRM_EMAIL_ADDRESSES=true

# =============================================================================
# Single-Site Configuration (only applies when MULTISITE_MODE=false)
# =============================================================================
# Site subdomain identifier (used in config.json and database)
# SITE_SUBDOMAIN=std

# Site and consultation display names
# SITE_TITLE=Demo Site
# CONSULTATION_PATH=main
# CONSULTATION_TITLE=Main Consultation
# CONSULTATION_TITLE_SHORT=Main

# =============================================================================
# Redis (Optional but recommended)
# =============================================================================
# Redis is automatically enabled when REDIS_HOST is set
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# =============================================================================
# Mail Configuration
# =============================================================================
# Option 1: Symfony Mailer DSN (recommended)
MAILER_DSN=smtp://mailpit:1025

# Option 2: Individual SMTP settings (alternative to MAILER_DSN)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_ENCRYPTION=tls

# Sender information
MAIL_FROM_EMAIL=noreply@localhost
MAIL_FROM_NAME=Antragsgruen

# =============================================================================
# Tool Paths (Optional)
# =============================================================================
# IMAGE_MAGICK_PATH=/usr/bin/convert
# WEASYPRINT_PATH=/usr/bin/weasyprint
# PDFUNITE_PATH=/usr/bin/pdfunite

# =============================================================================
# Container Settings
# =============================================================================
HTTP_PORT=8080
RUN_MIGRATIONS=true

# Development only - Mailpit web UI
MAILPIT_WEB_PORT=8025

# =============================================================================
# OIDC / SSO Configuration (Optional)
# =============================================================================
# Enable OIDC-based Single Sign-On
# OIDC_ENABLED=false

# Required when OIDC is enabled:
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_ISSUER=https://auth.example.com/oidc

# Optional OIDC settings (sensible defaults provided):
# OIDC_REDIRECT_URI=                   # Default: ${APP_PROTOCOL}://${APP_DOMAIN}/sso-callback
# OIDC_SCOPES=openid,profile,email     # Comma-separated scopes
# OIDC_PKCE=true                       # Enable PKCE
# OIDC_SINGLE_LOGOUT=true              # Enable single logout
# OIDC_SYNC_GROUPS=false               # Sync groups from IdP
# OIDC_DISCOVERY=true                  # Auto-fetch endpoints from .well-known

# Manual endpoint overrides (only needed when OIDC_DISCOVERY=false):
# OIDC_URL_AUTHORIZE=
# OIDC_URL_TOKEN=
# OIDC_URL_USERINFO=
# OIDC_URL_LOGOUT=

# Attribute mapping overrides:
# OIDC_ATTR_EMAIL=email
# OIDC_ATTR_USERNAME=preferred_username
# OIDC_ATTR_GIVEN_NAME=given_name
# OIDC_ATTR_FAMILY_NAME=family_name
# OIDC_ATTR_GROUPS=groups

# Group mapping (JSON string):
# OIDC_GROUP_MAPPING={"idp-admins":"admin","idp-users":"user"}
